APP_ENV=production
APP_TIMEZONE=Europe/Moscow
DATABASE_URL=postgresql+asyncpg://procurement:procurement@postgres:5432/procurement
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/google-service-account.json
GOOGLE_SERVICE_ACCOUNT_FILE=./secrets/google-service-account.json
GOOGLE_SPREADSHEET_ID=
GOOGLE_MAIN_SHEET=2026 (44)
GOOGLE_REVIEW_SHEET=Требуется проверка
DOCUMENT_CACHE_DIR=/var/cache/procurement-documents
EIS_BASE_URL=https://zakupki.gov.ru
EIS_MIN_REQUEST_INTERVAL_SECONDS=1.2
EIS_VERIFY_SSL=true
EIS_CA_BUNDLE=/app/certs/eis-ca-bundle.pem
SCHEDULER_INTERVAL_MINUTES=30
HEALTH_HOST=0.0.0.0
HEALTH_PORT=8080
WEB_UI_ENABLED=true
WEB_UI_TOKEN=
